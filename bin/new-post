#!/usr/bin/env bash

set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: bin/new-post \"Post Title\"" >&2
  exit 1
fi

title="$*"
date_part="$(date +%F)"
slug="$(printf '%s' "$title" \
  | tr '[:upper:]' '[:lower:]' \
  | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"

if [ -z "$slug" ]; then
  echo "Could not derive a filename slug from title: $title" >&2
  exit 1
fi

post_path="_posts/${date_part}-${slug}.md"

if [ -e "$post_path" ]; then
  echo "Post already exists: $post_path" >&2
  exit 1
fi

cat > "$post_path" <<EOF
---
title: $title
---

EOF

echo "Created $post_path"
